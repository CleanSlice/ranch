import { Usage } from "../usage/usage"
import { Agent } from "../agent/agent/agent"

model LlmCredential {
  id            String   @id @default(uuid())
  provider      String
  model         String
  fallbackModel String?
  label         String?
  apiKey        String
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  usages Usage[]
  agents Agent[]

  @@index([status])
}
