import { Agent } from "../agent/agent"
import { Skill } from "../../skill/skill"
import { McpServer } from "../../mcpServer/mcpServer"
import { PaddockScenario } from "../../paddock/scenario/scenario"

model Template {
  id                  String            @id @default(uuid())
  name                String            @unique
  description         String
  image               String
  defaultConfig       Json              @default("{}")
  // 2 CPU / 2Gi RAM is the realistic minimum for a runtime that spins up
  // its own headless Chromium for browser_play. 500m/512Mi (the original
  // default) starved Chromium on launch — every X/Instagram screenshot
  // hit the 120s tool timeout because the browser never finished booting.
  defaultResources    Json              @default("{\"cpu\": \"2000m\", \"memory\": \"2Gi\"}")
  paddockConfig       Json              @default("{}")
  defaultKnowledgeIds String[]          @default([])
  sourceUrl           String?
  sourceType          String?
  manifestJson        Json?
  version             String?
  agents              Agent[]
  skills              Skill[]
  mcpServers          McpServer[]
  paddockScenarios    PaddockScenario[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}
