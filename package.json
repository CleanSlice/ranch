{
  "name": "ranch",
  "version": "0.2.0",
  "private": true,
  "packageManager": "bun@1.2.12",
  "workspaces": [
    "api",
    "app",
    "admin"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:api": "turbo dev --filter=api",
    "dev:app": "turbo dev --filter=app",
    "dev:admin": "turbo dev --filter=admin",
    "release": "npm version --message 'chore(release): v%s'"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "dependencies": {
    "@cleanslice/paddock": "^0.2.3"
  }
}
