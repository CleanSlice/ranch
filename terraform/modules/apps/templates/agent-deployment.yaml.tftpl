apiVersion: argoproj.io/v1alpha1
kind: WorkflowTemplate
metadata:
  name: agent-deployment
  namespace: agents
spec:
  entrypoint: deploy-agent
  serviceAccountName: workflow
  arguments:
    parameters:
      - name: agent-id
      - name: agent-name
      - name: template-id
      - name: agent-image
      # Base64-encoded JSON. Raw JSON cannot be safely substituted into the
      # double-quoted YAML scalar in agent-pod.manifest below — its inner `"`
      # would terminate the surrounding string. Base64 sidesteps that.
      - name: agent-config-b64
        value: "e30="
      - name: cpu-limit
        value: "500m"
      - name: memory-limit
        value: "512Mi"
      - name: image-pull-policy
        value: "Always"
      - name: bridle-url
        value: ""
      - name: bridle-api-key
        value: ""
      - name: s3-bucket
        value: ""
      - name: s3-prefix
        value: ""
      - name: s3-endpoint
        value: ""
      - name: aws-region
        value: "us-east-1"
      - name: aws-access-key-id
        value: ""
      - name: aws-secret-access-key
        value: ""
      # Secret storage backend for the runtime (file | aws)
      - name: secret-provider
        value: "file"
      - name: aws-secret-prefix
        value: "cleanslice/users"
      # Ranch admin mode — when "true" the runtime registers ranch_* tools
      # and the agent can manage this Ranch through its REST API.
      - name: ranch-admin
        value: "false"
      - name: ranch-api-url
        value: ""
      - name: ranch-api-token
        value: ""
      # MCP servers — base64(JSON array of IMcpServerConfig), populated by the
      # api at deploy time from the agent's template's attached MCP servers.
      # Base64 to avoid breaking the surrounding YAML string (see agent-config-b64).
      - name: mcp-servers-b64
        value: "W10="
      # LLM contract for the runtime (LLM_* env on the pod)
      - name: llm-provider
        value: ""
      - name: llm-model
        value: ""
      - name: llm-fallback-model
        value: ""
      - name: llm-api-key
        value: ""
      # Auxiliary LLM (runtime ≥ 0.4.0): cheaper/smaller model for background
      # work — session compaction, memory-flush, future curator/insights.
      # When all four are empty, runtime's aux falls back to the main LLM.
      # Setting just llm-aux-model is enough: aux inherits provider/key from
      # main and uses the smaller model. See runtime/IMPROVEMENT_PLAN.md #1.
      - name: llm-aux-provider
        value: ""
      - name: llm-aux-model
        value: ""
      - name: llm-aux-fallback-model
        value: ""
      - name: llm-aux-api-key
        value: ""
  templates:
    - name: deploy-agent
      steps:
        - - name: cleanup-old
            template: cleanup-pod
            continueOn:
              failed: true
        - - name: run-agent
            template: agent-pod

    - name: cleanup-pod
      resource:
        action: delete
        flags: ["--ignore-not-found", "--wait=true", "--timeout=30s"]
        manifest: |
          apiVersion: v1
          kind: Pod
          metadata:
            name: "agent-{{workflow.parameters.agent-id}}"
            namespace: agents

    - name: agent-pod
      resource:
        action: create
        successCondition: status.phase == Running
        # Treat Succeeded as failure: a runtime image with no command (e.g.
        # vanilla `node:18-alpine`) exits with code 0 in <1s, so the pod
        # skips Running and goes straight to Succeeded. Without this,
        # Argo retries the resource watch forever.
        failureCondition: status.phase in (Failed, Succeeded)
        manifest: |
          apiVersion: v1
          kind: Pod
          metadata:
            name: "agent-{{workflow.parameters.agent-id}}"
            namespace: agents
            labels:
              app: ranch-agent
              ranch/agent-id: "{{workflow.parameters.agent-id}}"
              ranch/template-id: "{{workflow.parameters.template-id}}"
          spec:
            restartPolicy: Never
            nodeSelector:
              node-role: agents
            tolerations:
              - key: workload
                value: agent
                effect: NoSchedule
            imagePullSecrets:
              - name: ghcr
            containers:
              - name: agent
                image: "{{workflow.parameters.agent-image}}"
                imagePullPolicy: "{{workflow.parameters.image-pull-policy}}"
                env:
                  - name: AGENT_ID
                    value: "{{workflow.parameters.agent-id}}"
                  - name: AGENT_NAME
                    value: "{{workflow.parameters.agent-name}}"
                  - name: AGENT_CONFIG_B64
                    value: "{{workflow.parameters.agent-config-b64}}"
                  - name: BRIDLE_URL
                    value: "{{workflow.parameters.bridle-url}}"
                  - name: BRIDLE_API_KEY
                    value: "{{workflow.parameters.bridle-api-key}}"
                  - name: BRIDLE_AGENT_ID
                    value: "{{workflow.parameters.agent-id}}"
                  - name: S3_BUCKET
                    value: "{{workflow.parameters.s3-bucket}}"
                  - name: S3_PREFIX
                    value: "{{workflow.parameters.s3-prefix}}"
                  - name: S3_ENDPOINT
                    value: "{{workflow.parameters.s3-endpoint}}"
                  - name: AWS_REGION
                    value: "{{workflow.parameters.aws-region}}"
                  - name: AWS_ACCESS_KEY_ID
                    value: "{{workflow.parameters.aws-access-key-id}}"
                  - name: AWS_SECRET_ACCESS_KEY
                    value: "{{workflow.parameters.aws-secret-access-key}}"
                  - name: SECRET_PROVIDER
                    value: "{{workflow.parameters.secret-provider}}"
                  - name: AWS_SECRET_PREFIX
                    value: "{{workflow.parameters.aws-secret-prefix}}"
                  - name: LLM_PROVIDER
                    value: "{{workflow.parameters.llm-provider}}"
                  - name: LLM_MODEL
                    value: "{{workflow.parameters.llm-model}}"
                  - name: LLM_FALLBACK_MODEL
                    value: "{{workflow.parameters.llm-fallback-model}}"
                  - name: LLM_API_KEY
                    value: "{{workflow.parameters.llm-api-key}}"
                  - name: LLM_AUX_PROVIDER
                    value: "{{workflow.parameters.llm-aux-provider}}"
                  - name: LLM_AUX_MODEL
                    value: "{{workflow.parameters.llm-aux-model}}"
                  - name: LLM_AUX_FALLBACK_MODEL
                    value: "{{workflow.parameters.llm-aux-fallback-model}}"
                  - name: LLM_AUX_API_KEY
                    value: "{{workflow.parameters.llm-aux-api-key}}"
                  - name: RANCH_ADMIN
                    value: "{{workflow.parameters.ranch-admin}}"
                  - name: RANCH_API_URL
                    value: "{{workflow.parameters.ranch-api-url}}"
                  - name: RANCH_API_TOKEN
                    value: "{{workflow.parameters.ranch-api-token}}"
                  - name: MCP_SERVERS_B64
                    value: "{{workflow.parameters.mcp-servers-b64}}"
                resources:
                  requests:
                    cpu: "{{workflow.parameters.cpu-limit}}"
                    memory: "{{workflow.parameters.memory-limit}}"
                  limits:
                    cpu: "{{workflow.parameters.cpu-limit}}"
                    memory: "{{workflow.parameters.memory-limit}}"
                ports:
                  - containerPort: 3000
                # Runtime starts Bun.serve AFTER await runtime.start() finishes —
                # the channels are connected, S3 is pulled, the loop is wired.
                # Probing port 3000 means "agent is actually ready", not just
                # "container PID 1 exists". Without this the API reconciler flips
                # status to 'running' the moment kubelet reports container started.
                startupProbe:
                  httpGet:
                    path: /
                    port: 3000
                  periodSeconds: 2
                  failureThreshold: 90
                readinessProbe:
                  httpGet:
                    path: /
                    port: 3000
                  periodSeconds: 5
                  failureThreshold: 3
