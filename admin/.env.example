# API connection
# NUXT_PUBLIC_API_URL feeds runtimeConfig.public.apiUrl, which the
# apiBaseUrl plugin reads to set the axios baseURL on the client.
# (Plain API_URL is NOT exposed to the client bundle.)
NUXT_PUBLIC_API_URL=http://localhost:3333
API_URL=http://localhost:3333
