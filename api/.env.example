NODE_ENV=dev
PORT=3333
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

DATABASE_URL=postgresql://postgres:root@localhost:5432/ranch-local

ARGO_WORKFLOWS_URL=http://localhost:2746

JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# Workflow runtime: 'argo' (real Argo at ARGO_WORKFLOWS_URL) or 'mock' (in-memory stub)
WORKFLOW_PROVIDER=argo

BRIDLE_API_KEY=dev-bridle-api-key-change-me
