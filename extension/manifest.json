{
  "manifest_version": 3,
  "name": "Ranch Cookies",
  "short_name": "Ranch",
  "version": "0.1.0",
  "description": "Send cookies for the current site to your Ranch agent so it can drive logged-in browser sessions without VNC.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send cookies to Ranch"
  },
  "permissions": ["cookies", "storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
