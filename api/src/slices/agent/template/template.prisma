import { Agent } from "../agent/agent"
import { Skill } from "../../skill/skill"
import { McpServer } from "../../mcpServer/mcpServer"
import { PaddockScenario } from "../../paddock/scenario/scenario"

model Template {
  id               String      @id @default(uuid())
  name             String      @unique
  description      String
  image            String
  defaultConfig    Json        @default("{}")
  defaultResources Json        @default("{\"cpu\": \"500m\", \"memory\": \"512Mi\"}")
  paddockConfig    Json        @default("{}")
  // Provenance — populated by templateInstall when the template was created
  // from an installable manifest. Null for templates created by the legacy
  // direct-CRUD endpoints. version follows semver from manifest.metadata.
  sourceUrl        String?
  sourceType       String?
  manifestJson     Json?
  version          String?
  agents           Agent[]
  skills           Skill[]
  mcpServers       McpServer[]
  paddockScenarios PaddockScenario[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}
