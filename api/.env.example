NODE_ENV=dev
PORT=3333
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002

DATABASE_URL=postgresql://postgres:root@localhost:5432/ranch-local

ARGO_WORKFLOWS_URL=http://localhost:2746

JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# Workflow runtime: 'argo' (real Argo at ARGO_WORKFLOWS_URL) or 'mock' (in-memory stub)
WORKFLOW_PROVIDER=argo

BRIDLE_API_KEY=dev-bridle-api-key-change-me

# Browser-pool — keep TOKEN in sync with docker-compose.yml's browserless service.
# INTERNAL_URL is the hostname embedded in the CDP URL handed to the agent
# runtime. From inside k3d agent pods, ranch-browserless resolves over the
# k3d docker network. PUBLIC_URL is what end users open in a browser for VNC.
BROWSER_POOL_TOKEN=dev-browser-pool-token-change-me
BROWSER_POOL_INTERNAL_URL=ws://ranch-browserless:3000
BROWSER_POOL_PUBLIC_URL=http://localhost:13000
BROWSER_POOL_PLAYWRIGHT_PATH=/chromium/playwright
BROWSER_POOL_VNC_URL_TEMPLATE=/live?id={sessionId}&token={token}

LIGHTRAG_URL=http://localhost:9621
LIGHTRAG_API_KEY=changeme
OPENAI_API_KEY=
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
REINS_S3_BUCKET=ranch-reins-sources
