import { Usage } from "../usage/usage"

model LlmCredential {
  id        String   @id @default(uuid())
  provider  String
  model     String
  label     String?
  apiKey    String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usages Usage[]

  @@index([status])
}
