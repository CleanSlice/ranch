{
  "name": "ranch",
  "private": true,
  "packageManager": "bun@1.2.12",
  "workspaces": [
    "api",
    "app",
    "admin",
    "cli"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
