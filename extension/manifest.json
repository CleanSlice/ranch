{
  "manifest_version": 3,
  "name": "Ranch Cookies",
  "short_name": "Ranch",
  "version": "0.2.0",
  "description": "Send cookies for the current site to a Ranch integration (per-user) or directly to a specific agent. Skip VNC by reusing the logged-in session in your normal browser.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send cookies to Ranch"
  },
  "permissions": ["cookies", "storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
