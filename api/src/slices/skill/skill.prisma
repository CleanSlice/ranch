import { Template } from "../agent/template/template"

model Skill {
  id          String   @id @default(uuid())
  name        String   @unique
  title       String
  description String?
  body        String   // SKILL.md content
  files       Json     @default("[]")  // sibling files: [{ path: "references/x.md", content: "…" }]
  source      String?  // origin URL when imported (e.g. github.com/owner/repo/path)
  templates   Template[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}
