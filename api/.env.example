# Workflow runtime: 'argo' (real Argo at ARGO_WORKFLOWS_URL) or 'mock' (in-memory stub)
WORKFLOW_PROVIDER=argo

BRIDLE_API_KEY=dev-bridle-api-key-change-me

LIGHTRAG_URL=http://localhost:9621
LIGHTRAG_API_KEY=changeme
OPENAI_API_KEY=
S3_ENDPOINT=http://localhost:9000
