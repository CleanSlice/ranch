apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ranch-api
  namespace: platform
  annotations:
    cert-manager.io/cluster-issuer: ${issuer}
    traefik.ingress.kubernetes.io/router.entrypoints: web,websecure
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - ${host}
      secretName: ranch-api-tls
  rules:
    - host: ${host}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: ranch-api
                port:
                  number: 80
